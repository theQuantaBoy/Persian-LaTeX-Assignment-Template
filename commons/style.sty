% ------------------------------------------------------------------------
% style.sty - Persian assignment / report template (XeLaTeX)
% Intended for Sharif University of Technology (customizable).
% Most users only need to edit main.tex; this file is for style-level changes.
% ------------------------------------------------------------------------
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{commons/style}[2026/04/27 v2.0 Persian Assignment Style]

% ------------------------------------------------------------------------
% Package options
% - minted: requires -shell-escape and Python/Pygments
% - listings (default): works without -shell-escape (Overleaf-friendly)
% ------------------------------------------------------------------------
\newif\ifcommonsminted
\commonsmintedfalse
\DeclareOption{minted}{\commonsmintedtrue}
\DeclareOption{listings}{\commonsmintedfalse}
\ProcessOptions\relax

% ------------------------------------------------------------------------
% 1. Required Packages
% ------------------------------------------------------------------------
\RequirePackage[margin=1in]{geometry}
\RequirePackage{graphicx, xcolor}
\RequirePackage{amsmath, amssymb, amsthm, mathtools}
\RequirePackage{physics}
\RequirePackage{array}
\RequirePackage[normalem]{ulem}
\RequirePackage{float} % provides [H] placement specifier
\RequirePackage{ifthen}
\RequirePackage{expl3}

\ifcommonsminted
	\RequirePackage[newfloat, outputdir=build]{minted}
\else
	\RequirePackage{listings}
	% Keeps \begin{minted}...\end{minted} working in listings mode.
	\providecommand{\setminted}[1]{\lstset{#1}}
	\lstnewenvironment{minted}[1]{\lstset{language=#1}}{}
\fi

\ifcommonsminted\else
	% Provide a "listing" float (minted's newfloat normally defines this)
	\newfloat{listing}{H}{lol}
	\floatname{listing}{کد}
\fi

\ifcommonsminted\else
	\lstset{
		basicstyle=\ttfamily\small,
		breaklines=true,
		numbers=left,
		numberstyle=\scriptsize,
		frame=lines,
		tabsize=4,
		columns=fullflexible
	}
\fi
\RequirePackage[colorlinks=true, linkcolor=blue, urlcolor=cyan, citecolor=green]{hyperref}
\RequirePackage{tikz}
\RequirePackage{xepersian} % Must be loaded last

% ------------------------------------------------------------------------
% Make missing images non-fatal (useful for sharing templates)
% ------------------------------------------------------------------------
\makeatletter
\let\commons@orig@includegraphics\includegraphics
\RenewDocumentCommand{\includegraphics}{ O{} m }{%
	\IfFileExists{#2}{%
		\commons@orig@includegraphics[#1]{#2}%
	}{%
		\fbox{\begin{minipage}{0.9\linewidth}\raggedright
				Missing image: \lr{#2}
			\end{minipage}}%
	}%
}
\makeatother

% ------------------------------------------------------------------------
% 2. Configurations & Styling
% ------------------------------------------------------------------------

% Code listing style
\ifcommonsminted
	\setminted{
		autogobble,
		linenos,
		breaklines,
		frame=lines,
		fontsize=\small,
		baselinestretch=1.2,
		tabsize=4
	}
\fi

% ------------------------------------------------------------------------
% Fonts
% ------------------------------------------------------------------------

% Persian text and digits
\settextfont[Scale=1.0,
	Path=fonts/,
	UprightFont=XBNiloofar.ttf,
	BoldFont=XBNiloofarBd.ttf,
	ItalicFont=XBNiloofarIt.ttf,
	BoldItalicFont=XBNiloofarBdIt.ttf
]{XBNiloofar}

\setdigitfont[Scale=1.0,
	Path=fonts/,
	UprightFont=XBNiloofar.ttf,
	BoldFont=XBNiloofarBd.ttf,
	ItalicFont=XBNiloofarIt.ttf,
	BoldItalicFont=XBNiloofarBdIt.ttf
]{XBNiloofar}

% Latin / English font
\setlatintextfont[Scale=1.0]{Latin Modern Roman}

% ------------------------------------------------------------------------
% Layout & Spacing
% ------------------------------------------------------------------------
\setlength{\parindent}{0em}
\setlength{\parskip}{.5em}
\renewcommand{\labelitemi}{\small$\bullet$}
\pagestyle{plain}

% Tables get a bit more breathing room
\renewcommand{\arraystretch}{1.3}

% Footnotes use smaller numbers
\renewcommand{\thefootnote}{\scriptsize\arabic{footnote}}

% Prevent LaTeX from stretching pages to an exact bottom margin
\raggedbottom

% Fix math spacing around display equations
\makeatletter
\g@addto@macro\normalsize{%
	\setlength\abovedisplayskip{.8em}
	\setlength\abovedisplayshortskip{.55em}
	\setlength\belowdisplayskip{.8em}
	\setlength\belowdisplayshortskip{.69em}
}
\makeatother

% ------------------------------------------------------------------------
% 3. Header Variables
% ------------------------------------------------------------------------
\makeatletter
\newcommand{\coursetitle}[1]{\def\@coursetitle{#1}}
\newcommand{\semester}[1]{\def\@semester{#1}}
\newcommand{\prof}[1]{\def\@prof{#1}}
\newcommand{\studentname}[1]{\def\@studentname{#1}}
\newcommand{\studentid}[1]{\def\@studentid{#1}}
\newcommand{\assignmenttype}[1]{\def\@assignmenttype{#1}}
\newcommand{\assignmenttitle}[1]{\def\@assignmenttitle{#1}}

\coursetitle{} \semester{} \prof{} \studentname{} \studentid{} \assignmenttype{} \assignmenttitle{}

% ------------------------------------------------------------------------
% 3.5. Report Cover Variables (for Lab Reports, Project Reports, etc.)
% ------------------------------------------------------------------------
\newcommand{\reportcoursename}[1]{\def\@reportcoursename{#1}}
\newcommand{\reportsemester}[1]{\def\@reportsemester{#1}}
\newcommand{\reportprof}[1]{\def\@reportprof{#1}}
\newcommand{\reportgroupmembers}[1]{\def\@reportgroupmembers{#1}} % use \\ for multiple names
\newcommand{\reportdepartment}[1]{\def\@reportdepartment{#1}}
\newcommand{\reportuniversity}[1]{\def\@reportuniversity{#1}}
\newcommand{\reportsubtitle}[1]{\def\@reportsubtitle{#1}}
\newcommand{\reporttitle}[1]{\def\@reporttitle{#1}}
\newcommand{\reportenglishtitle}[1]{\def\@reportenglishtitle{#1}}
\newcommand{\reportTS}[1]{\def\@reportTS{#1}}

% Defaults (empty)
\reportcoursename{}
\reportsemester{}
\reportprof{}
\reportgroupmembers{}
\reportdepartment{دانشکده‌ی مهندسی کامپیوتر}
\reportuniversity{دانشگاه صنعتی شریف}
\reportsubtitle{}
\reporttitle{}
\reportenglishtitle{}
\reportTS{}


% ------------------------------------------------------------------------
% 4. Custom Header Generation
% ------------------------------------------------------------------------
\newcommand{\heading}[4]{%
	\parindent=0em
	\noindent
	% Right Block (Logo and Uni Info)
	\begin{minipage}[b]{0.48\textwidth}
		\makebox[\textwidth][r]{\includegraphics[height=2.0cm]{commons/logo.png}}
		\\[0.3em]
		{\scriptsize\bfseries دانشگاه صنعتی شریف \\ دانشکده‌ی مهندسی کامپیوتر}
	\end{minipage}%
	\hfill
	% Left Block (Course and Student Info)
	\begin{minipage}[b]{0.48\textwidth}
		\makebox[\textwidth][l]{\LARGE\bfseries \@coursetitle}
		\\[0.3em]
		\makebox[\textwidth][l]{\bfseries \@semester}
		\\[0.3em]
		\makebox[\textwidth][l]{\small #4}
		\\[0.3em]
		\makebox[\textwidth][l]{\small #3}
	\end{minipage}

	\vspace{1.2em}
	\hrule height .12em
	\normalsize
	\vspace{0.0em}

	% Bottom Bar
	\noindent
	\makebox[5cm][r]{#1}%
	\hfill
	\makebox[5cm][c]{#2}%
	\hfill
	\makebox[5cm][l]{}

	\vspace{0.45em}
	\hrule height .12em
	\vspace{0.75em}
}

\makeatletter
\AtBeginDocument{%
	\renewcommand{\maketitle}{%
		\thispagestyle{empty}
		\heading
		{\@assignmenttype}%
		{\ifx\@assignmenttitle\empty\else\@assignmenttitle\fi}%
		{\@studentname\ - \@studentid}%
		{استاد: \@prof}%
		\thispagestyle{plain}
		\setcounter{page}{1}%
	}%
}
\makeatother

% ------------------------------------------------------------------------
% 4.5. Report Cover Page
% ------------------------------------------------------------------------
\newcommand{\makecover}{%
	\thispagestyle{empty}
	\begin{center}
		\includegraphics[height=2.5cm]{commons/logo.png}

		\vspace{-0.2cm}
		\@reportuniversity \\[-0.3em]
		\@reportdepartment \\

		\vspace{2cm} % Increased from 1.5cm

		% Subtitle
		\ifx\@reportsubtitle\empty\else
			{\@reportsubtitle}\\[1.0em]
		\fi

		% Report title
		\ifx\@reporttitle\empty\else
			{\LARGE\bfseries \@reporttitle}\\
			\vspace{1.5cm}
		\fi

		% English title
		\ifx\@reportenglishtitle\empty
			% Add extra space if no English title exists to balance the page
			\vspace{1.5cm}
		\else
			\begin{latin}
				{\Large\bfseries \@reportenglishtitle}
			\end{latin}
			\vspace{2.0cm}
		\fi

		% Group members
		\ifx\@reportgroupmembers\empty\else
			{اعضای گروه}\\[0.6em]
			{\large\bfseries \@reportgroupmembers}
			\vspace{1.5cm}
		\fi

		% Course name
		\ifx\@reportcoursename\empty\else
			{نام درس}\\[0.6em]
			{\large\bfseries \@reportcoursename}
			\vspace{1.5cm}
		\fi

		% Semester
		\ifx\@reportsemester\empty\else
			{\large\bfseries \@reportsemester}
			\vspace{1.5cm}
		\fi

		% Instructor
		\ifx\@reportprof\empty\else
			{نام استاد}\\[0.8em]
			{\large\bfseries \@reportprof}
			\vspace{1cm}
		\fi

		% Teaching assistant
		\ifx\@reportTS\empty\else
			{دستیار آموزشی}\\[0.8em]
			{\large\bfseries \@reportTS}
			\vspace{1.5cm}
		\fi

	\end{center}
	\newpage
	\thispagestyle{plain}
}

\makeatother

% ------------------------------------------------------------------------
% 5. Structural Commands
% ------------------------------------------------------------------------

% ------------------------------------------------------------------------
% Document type & front matter
% Usage:
%   \doctype{assignment} or \doctype{report}
%   \MakeFrontMatter
% ------------------------------------------------------------------------
\newif\ifcommonsreport
\commonsreportfalse
\NewDocumentCommand{\doctype}{m}{%
	\edef\commonsdoctype{#1}%
	\ifthenelse{\equal{\commonsdoctype}{report}}{\commonsreporttrue}{\commonsreportfalse}%
}
\NewDocumentCommand{\MakeFrontMatter}{}{%
	\ifcommonsreport
		\makecover
	\else
		\maketitle
	\fi
}

% Section-like centered heading
\newcommand{\sectiontitle}[1]{%
	\par\vspace*{0.5em}
	\begin{center}\Large #1\end{center}
	\vspace{0.3em}
}

% Question command without automatic page breaks
\newcounter{question}
\setcounter{question}{0}

\newcommand{\resetquestions}{\setcounter{question}{0}}

\NewDocumentCommand{\question}{ o m }{
	\IfValueTF{#1}
	{\setcounter{question}{#1}}
	{\stepcounter{question}}%
	\noindent\textbf{سوال \arabic{question}:} \textbf{#2}
}

% ------------------------------------------------------------------------
% Answer file helpers
% Usage: \answers{theory1,theory2}
% Expands to: \input{answers/theory1} \clearpage \input{answers/theory2}
% ------------------------------------------------------------------------
\ExplSyntaxOn
\NewDocumentCommand{\answers}{m}{
	\bool_set_true:N \l__commons_answers_first_bool
	\clist_map_inline:nn { #1 } {
		\bool_if:NF \l__commons_answers_first_bool { \clearpage }
		\bool_set_false:N \l__commons_answers_first_bool
		\input{answers/##1}
	}
}
\bool_new:N \l__commons_answers_first_bool
\ExplSyntaxOff

% Persian proof environment
\renewenvironment{proof}{\begin{trivlist}\item[\hskip\labelsep{\em اثبات.}]}{\hspace*{\fill}\ensuremath{\square}\end{trivlist}}

% Subsection formatting
\makeatletter
\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}
	{-2ex}
	{0.5ex}
	{\normalfont\normalsize\bfseries}
}

% ------------------------------------------------------------------------
% Persian Enumerations
% ------------------------------------------------------------------------

\def\harfi#1{\expandafter\@harfi\csname c@#1\endcsname}   % alef, be, pe, te, ...
\def\abjad#1{\expandafter\@abjad\csname c@#1\endcsname}   % alef, be, jim, dal, ...
\def\adadi#1{\expandafter\@adadi\csname c@#1\endcsname}   % yek, do, se, ...
\def\Aharfi#1{\expandafter\@Aharfi\csname c@#1\endcsname} % alef, be, pe, te, ... (tak harfi)

\def\@harfi#1{\beginR\@@harfi#1\endR}
\def\@@harfi#1{%
	\ifcase#1\or الف\or ب\or پ\or ت\or ث\or ج\or چ\or ح\or خ\or د\or ذ\or ر\or ز\or ژ\else\@ctrerr\fi}

\def\@abjad#1{\beginR\@@abjad#1\endR}
\def\@@abjad#1{%
	\ifcase#1\or آ\or ب\or ج\or د\or ه\or و\or ز\or ح\or ط\or ی\or ک\or ل\or م\or ن\else\@ctrerr\fi}

\def\@adadi#1{\beginR\@@adadi#1\endR}
\def\@@adadi#1{%
	\ifcase#1 یک\or دو\or سه\or چهار\or پنج\or شش\or هفت\or هشت\or نه\or ده\else\@ctrerr\fi}

\def\@Aharfi#1{\beginR\@@Aharfi#1\endR}
\def\@@Aharfi#1{%
	\ifcase#1\or آ\or ب\or پ\or ت\or ث\or ج\or چ\or ح\or خ\or د\or ذ\or ر\or ز\or ژ\else\@ctrerr\fi}

% List environments using the above counters
\newcounter{alef}
\newenvironment{ابجد}{%
	\setcounter{alef}{0}
	\begin{list}{(\abjad{alef})}
		{\usecounter{alef}}}
		{\end{list}}

\newenvironment{الفبا}{%
	\setcounter{alef}{0}
	\begin{list}{(\Aharfi{alef})}
		{\usecounter{alef}}}
		{\end{list}}

